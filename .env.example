# Copy this to .env.local (gitignored) and fill in the token.
# Set the same three in Vercel → Settings → Environment Variables for production.

# Airtable Personal Access Token, scoped to this base with
# data.records:write and schema.bases:read
AIRTABLE_TOKEN=your_personal_access_token

# The submissions base + pitches table
AIRTABLE_BASE_ID=appfg2LjCjfMDUdI6
AIRTABLE_TABLE=Pitches
