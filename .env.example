# Copy this to .env.local (gitignored) and fill in the values.
# In production these are provided by the Vercel <-> Sanity integration; set
# REVALIDATE_SECRET yourself in Vercel -> Settings -> Environment Variables.

# Sanity project the site reads reviews and editable copy from.
# Local dev typically points at the development dataset.
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=development

# Write token — only needed to run the seed scripts (scripts/sanity-seed*.mts).
# The site itself reads a public dataset with no token.
SANITY_API_WRITE_TOKEN=your_write_token

# Shared secret for the on-demand revalidation webhook (POST /api/revalidate).
# Must match the value configured on the Sanity webhook.
REVALIDATE_SECRET=any_long_random_string
